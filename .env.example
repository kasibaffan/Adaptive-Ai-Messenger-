SECRET_KEY=your_super_secret_jwt_key_change_this

# Default: local SQLite, zero setup, fine for development/demo.
# Production: point this at a managed Postgres instance instead, e.g.:
# DATABASE_URL=postgresql+psycopg://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./messenger.db

# Comma-separated list of origins allowed to call the dashboard/admin API
# (auth, documents, reminders, gaps, chat logs). The public chat-send endpoint
# (POST /chat/{company_id}) is exempt by design — companies embed the widget
# on their own customer-facing websites, so it must accept any origin.
ALLOWED_ORIGINS=http://localhost:8000

# Optional: leave blank to run without real email delivery (reminders are logged instead)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=

# Optional: leave blank to run without billing — the dashboard shows a
# "billing not configured yet" message instead of erroring. Stripe test-mode
# keys are free to create (no card required) at https://dashboard.stripe.com.
# STRIPE_SECRET_KEY is the API key, STRIPE_WEBHOOK_SECRET verifies webhook
# deliveries, STRIPE_PRO_PRICE_ID is the Price ID for your "Pro" plan product.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
APP_BASE_URL=http://localhost:8000

# Optional: override where uploaded files and the Chroma vector store live on
# disk. Defaults below are fine for a single-server dev/demo setup.
UPLOAD_DIR=./uploads
CHROMA_STORE_PATH=./chroma_store

# Optional: leave blank to keep uploaded documents on local disk only (fine
# for a single persistent server). On hosts with ephemeral disks, configure
# S3-compatible storage for a durable backup of raw uploads — Cloudflare R2
# has a free tier (10GB) with no card required: https://dash.cloudflare.com.
# Leave S3_ENDPOINT_URL blank to use AWS S3 instead of an S3-compatible host.
S3_BUCKET=
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto

# Optional: leave blank to skip error tracking — errors still get logged to
# stdout either way. Sentry's free tier (5k errors/month, no card required)
# is at https://sentry.io.
SENTRY_DSN=
LOG_LEVEL=INFO

# Optional: leave blank to keep reminders email-only (still works fully
# without these — see SMTP_* above). Twilio gives free trial credit, and the
# WhatsApp Sandbox is free for development/testing; sign up at
# https://www.twilio.com/try-twilio. TWILIO_SMS_FROM_NUMBER is your Twilio
# phone number; TWILIO_WHATSAPP_FROM_NUMBER is your Twilio WhatsApp-enabled
# number in the form "whatsapp:+14155238886" (the sandbox number Twilio gives
# you for testing, or a Business-approved number in production).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM_NUMBER=
TWILIO_WHATSAPP_FROM_NUMBER=

# Slack notifications are configured per-company in the dashboard Settings
# tab (a pasted Incoming Webhook URL) — nothing to set here.
